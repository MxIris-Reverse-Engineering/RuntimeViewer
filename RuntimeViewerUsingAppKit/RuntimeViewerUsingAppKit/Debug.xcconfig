//#include "Shared-Debug.xcconfig"

SMPrivilegedExecutable = identifier "com.JH.RuntimeViewerService" and anchor apple generic and certificate leaf[subject.CN] = "Apple Development: JieHui Lai (4ZZALU97YZ)" and certificate 1[field.1.2.840.113635.100.6.2.1] /* exists */


// Sparkle feed URL is hardcoded in Info.plist (SUFeedURL) because xcconfig's `//`
// comment rule makes URL values awkward to express here.
// TODO: Replace with the base64 EdDSA public key produced by Task 1 (generate_keys).
// Until then, Sparkle will refuse to accept any update (signature verification fails),
// but the app will still launch and the Check for Updates… menu item is functional.
SPARKLE_PUBLIC_ED_KEY = REPLACE_WITH_PUBLIC_ED_KEY_FROM_TASK_1
