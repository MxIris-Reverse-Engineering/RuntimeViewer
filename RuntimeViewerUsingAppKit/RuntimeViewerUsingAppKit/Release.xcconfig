//#include "Shared-Release.xcconfig"

SMPrivilegedExecutable = anchor apple generic and identifier "com.JH.RuntimeViewerService" and (certificate leaf[field.1.2.840.113635.100.6.1.9] /* exists */ or certificate 1[field.1.2.840.113635.100.6.2.6] /* exists */ and certificate leaf[field.1.2.840.113635.100.6.1.13] /* exists */ and certificate leaf[subject.OU] = D5Q73692VW)

// Sparkle feed URL is hardcoded in Info.plist (SUFeedURL) because xcconfig's `//`
// comment rule makes URL values awkward to express here.
// TODO: Replace with the base64 EdDSA public key produced by Task 1 (generate_keys)
// before cutting any release. Without a real key, Release builds ship an app that
// refuses every update.
SPARKLE_PUBLIC_ED_KEY = REPLACE_WITH_PUBLIC_ED_KEY_FROM_TASK_1
