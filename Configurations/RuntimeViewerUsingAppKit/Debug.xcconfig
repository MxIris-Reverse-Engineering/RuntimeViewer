#include "../CodeSigning.xcconfig"
//#include "../Shared/Debug.xcconfig"

SMPrivilegedExecutable = $(RUNTIME_VIEWER_DEBUG_SM_PRIVILEGED_EXECUTABLE)

// LaunchDaemon helper identity for Debug builds. (Debug-arm64e overrides this in the app
// target's Debug-arm64e build settings with dev.arm64e.mxiris.runtimeviewer.service.)
// Single build-time source consumed by the merged service target's PRODUCT_NAME, the
// build-time-generated launchd plist (name / Label / MachServices / EnvironmentVariables),
// and the app Info.plist RuntimeViewerServiceName key. At runtime RuntimeViewerMachServiceName
// reads it back: launchd env for the daemon, Info.plist for the app.
RUNTIME_VIEWER_SERVICE_NAME = dev.mxiris.runtimeviewer.service

RUNTIME_VIEWER_BUILD_DATE = unknown
RUNTIME_VIEWER_GIT_BRANCH = unknown
RUNTIME_VIEWER_GIT_COMMIT = unknown

// Sparkle feed URL is hardcoded in Info.plist (SUFeedURL) because xcconfig's `//`
// comment rule makes URL values awkward to express here.
// Matching EdDSA private key lives in the login Keychain; see Documentations/SparkleRelease.md.
SPARKLE_PUBLIC_ED_KEY = jlL11Arlrn0YtrQn66hxwUZeBI6dFxP2Wluq6eEYzss=
